<% if (locals.bundleExport) { %>
<!DOCTYPE html>
<html lang="bn" class="pdf-export">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Medical Report</title>
  <%- typeof pdfHeadExtras !== 'undefined' ? pdfHeadExtras : '' %>
</head>
<body class="pdf-export">
<% } else { %>
<%- include('partials/header') %>
<%- include('partials/navbar') %>
<% } %>

<style>
  :root {
    --a4-width: 210mm;
    --a4-height: 297mm;
    --a4-margin: 10mm;
    --a4-content-width: calc(var(--a4-width) - (var(--a4-margin) * 2));
    --a4-content-height: calc(var(--a4-height) - (var(--a4-margin) * 2));
  }

  @page {
    size: 210mm 297mm portrait;
    margin: 10mm;
  }

  html.medical-report-print,
  html.medical-report-print body {
    background: #e9ecef;
  }

  .print-report {
    font-family: 'Noto Sans Bengali', 'Nirmala UI', 'Kalpurush', Arial, sans-serif;
    width: var(--a4-content-width);
    max-width: var(--a4-content-width);
    min-height: var(--a4-content-height);
    margin: 0 auto;
    padding: 0;
    color: #000;
    background: #fff;
    font-size: 14px;
    box-sizing: border-box;
    box-shadow: 0 0 0 1px #dee2e6;
  }

  .print-page-shell {
    width: var(--a4-width);
    max-width: var(--a4-width);
    min-height: var(--a4-height);
    margin: 0 auto;
    padding: var(--a4-margin);
    box-sizing: border-box;
    background: #fff;
  }

  .report-title {
    text-align: center;
    font-size: 26px;
    font-weight: bold;
    text-transform: uppercase;
    margin: 0 0 4px;
    line-height: 1.2;
  }

  .report-subtitle {
    text-align: center;
    font-size: 18px;
    font-weight: 600;
    margin: 0 0 6px;
  }

  .report-clinic-info {
    text-align: center;
    font-size: 15px;
    margin-bottom: 10px;
    line-height: 1.35;
  }

  .report-meta-table,
  .report-table {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
  }

  .report-meta-table td,
  .report-table th,
  .report-table td {
    border: 1px solid #000;
    vertical-align: top;
  }

  .report-meta-table td {
    padding: 3px 10px;
  }

  .report-meta-table .meta-text-left,
  .report-meta-table .meta-text-right {
    width: auto;
    vertical-align: middle;
  }

  .report-meta-table .meta-photo,
  .report-meta-table .meta-fingerprint {
    width: 145px;
    text-align: center;
    vertical-align: middle;
    padding: 2px 6px;
  }

  .report-header-blank {
    display: flex;
    align-items: stretch;
    border: 1px solid #000;
    min-height: 155px;
  }

  .header-blank-body {
    flex: 1;
    display: flex;
    min-width: 0;
    border-right: 1px solid #000;
  }

  .header-blank-patient {
    flex: 1;
    padding: 6px 10px;
    display: flex;
    gap: 16px;
    align-items: stretch;
    border-right: 1px solid #000;
  }

  .header-blank-col {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 1px;
    justify-content: center;
  }

  .header-blank-field {
    font-size: 14px;
    line-height: 1.25;
    margin: 0;
  }

  .header-blank-room {
    width: 220px;
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 0;
  }

  .header-blank-room-table {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
    height: 100%;
  }

  .header-blank-room-table td {
    border: 1px solid #000;
    padding: 3px 6px;
    font-size: 12px;
    line-height: 1.2;
    vertical-align: middle;
  }

  .header-blank-room-table .room-title-row td {
    background: #e9ecef;
    text-align: center;
    font-weight: 700;
    font-size: 13px;
    padding: 4px 6px;
  }

  .header-blank-room-table .room-label-cell {
    width: 62%;
  }

  .header-blank-room-table .room-blank-cell {
    width: 38%;
    min-height: 18px;
  }

  .header-blank-photo {
    width: 145px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4px;
  }

  .patient-photo-img {
    width: 130px;
    height: 155px;
    object-fit: cover;
    border: 1px solid #999;
    display: block;
    margin: 0 auto;
    background: #f5f5f5;
  }

  .fingerprint-img {
    width: 110px;
    height: 135px;
    object-fit: contain;
    display: block;
    margin: 0 auto;
  }

  .meta-line {
    font-size: 15px;
    line-height: 1.25;
    margin: 0 0 1px;
  }

  .meta-line:last-child {
    margin-bottom: 0;
  }

  .report-columns {
    display: flex;
    gap: 8px;
    margin-top: 10px;
  }

  .report-columns > div {
    flex: 1;
    min-width: 0;
  }

  .report-table-2col col.col-name { width: 50%; }
  .report-table-2col col.col-value { width: 50%; }

  .biochem-nested-table {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
    margin: 0;
  }

  .biochem-nested-table col.col-name { width: 28%; }
  .biochem-nested-table col.col-result { width: 22%; }
  .biochem-nested-table col.col-ref { width: 50%; }

  .biochem-nested-table th,
  .biochem-nested-table td {
    border: 1px solid #000;
    padding: 2px 8px;
    font-size: 14px;
    line-height: 1.2;
    vertical-align: middle;
  }

  .biochem-cell {
    padding: 0 !important;
  }

  .report-table th,
  .report-table td {
    padding: 2px 8px;
    font-size: 14px;
    line-height: 1.2;
  }

  .report-table th {
    background: #f0f0f0;
    font-weight: 600;
    font-size: 14px;
  }

  .report-table .group-row td {
    background: #e9ecef;
    font-weight: 700;
    text-align: center;
    font-size: 15px;
    padding: 3px 8px;
  }

  .report-table .ref-value-cell {
    font-size: 11px;
    line-height: 1.25;
    white-space: pre-line;
    vertical-align: middle;
  }

  .xray-img {
    max-height: 130px;
    max-width: 100%;
    display: block;
    margin-top: 4px;
  }

  .sign-block {
    margin-top: 18px;
    text-align: right;
    padding-right: 30px;
  }

  .sign-line {
    border-top: 1px solid #000;
    width: 220px;
    display: inline-block;
    margin-top: 40px;
    padding-top: 6px;
    text-align: center;
    font-size: 15px;
  }

  .report-column-extra {
    margin-top: 8px;
  }

  .role-sign-table {
    margin-top: 8px;
  }

  .role-sign-table .group-row td {
    text-align: center;
    vertical-align: middle;
    height: auto;
    padding: 3px 8px;
  }

  .role-sign-table td {
    text-align: center;
    padding: 8px 6px 4px;
    vertical-align: bottom;
    height: 52px;
  }

  .role-sign-line {
    border-top: 1px solid #000;
    width: 85%;
    margin: 0 auto 4px;
    min-height: 28px;
  }

  .role-sign-label {
    font-size: 12px;
    line-height: 1.2;
    font-weight: 600;
  }

  .report-disclaimer-block {
    border: 1px solid #000;
    font-size: 12px;
    line-height: 1.45;
    text-align: center;
    padding: 8px 10px;
    margin: 0 0 10px;
    font-family: 'Noto Sans Bengali', 'Nirmala UI', 'Kalpurush', Arial, sans-serif;
  }

  .room-allocation-table {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
  }

  .room-allocation-table td {
    border: 1px solid #000;
    padding: 2px 8px;
    font-size: 14px;
    line-height: 1.2;
    vertical-align: middle;
  }

  .room-allocation-table td:last-child {
    text-align: center;
    font-weight: 700;
  }

  .report-footer {
    margin-top: 16px;
    padding-top: 10px;
  }

  .report-footer-note {
    text-align: center;
    font-size: 13px;
    line-height: 1.5;
    margin: 0 0 12px;
    font-family: 'Noto Sans Bengali', 'Nirmala UI', 'Kalpurush', Arial, sans-serif;
  }

  .report-final-check {
    text-align: end;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.5px;
    margin: 0;
  }

  @media print {
    @page {
      size: 210mm 297mm portrait;
      margin: 10mm;
    }

    html,
    body {
      width: 210mm !important;
      height: auto !important;
      margin: 0 !important;
      padding: 0 !important;
      background: #fff !important;
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }

    nav,
    .navbar,
    footer,
    .no-print {
      display: none !important;
    }

    .print-page-shell {
      width: 190mm !important;
      max-width: 190mm !important;
      min-height: auto !important;
      margin: 0 auto !important;
      padding: 0 !important;
      box-shadow: none !important;
      background: #fff !important;
    }

    .container,
    .print-report {
      width: 190mm !important;
      max-width: 190mm !important;
      min-height: auto !important;
      padding: 0 !important;
      margin: 0 auto !important;
      box-shadow: none !important;
      box-sizing: border-box !important;
      page-break-after: auto;
    }

    .print-report {
      font-size: 14px;
    }

    .report-title {
      font-size: 24px !important;
    }

    .report-subtitle {
      font-size: 17px !important;
    }

    .report-clinic-info {
      font-size: 14px !important;
    }

    .meta-line {
      font-size: 14px !important;
      line-height: 1.2 !important;
      margin-bottom: 1px !important;
    }

    .report-meta-table td {
      padding: 2px 8px !important;
    }

    .report-meta-table .meta-photo,
    .report-meta-table .meta-fingerprint {
      width: 145px !important;
    }

    .header-blank-field {
      font-size: 13px !important;
    }

    .header-blank-room {
      width: 200px !important;
    }

    .header-blank-room-table td {
      font-size: 10px !important;
      padding: 2px 4px !important;
    }

    .header-blank-room-table .room-title-row td {
      font-size: 11px !important;
      padding: 3px 4px !important;
    }

    .report-table th,
    .report-table td {
      font-size: 13px !important;
      padding: 2px 7px !important;
      line-height: 1.2 !important;
    }

    .report-table .group-row td {
      font-size: 14px !important;
      padding: 3px 7px !important;
    }

    .report-table .ref-value-cell {
      font-size: 9px !important;
      line-height: 1.2 !important;
    }

    .biochem-nested-table th,
    .biochem-nested-table td {
      font-size: 11px !important;
      padding: 2px 5px !important;
    }

    .patient-photo-img {
      width: 125px !important;
      height: 150px !important;
    }

    .fingerprint-img {
      width: 105px !important;
      height: 130px !important;
    }

    .xray-img {
      max-height: 120px !important;
    }

    .sign-line {
      font-size: 14px !important;
    }

    .role-sign-table .group-row td {
      padding: 3px 7px !important;
      height: auto !important;
    }

    .role-sign-table td {
      padding: 6px 4px 3px !important;
      height: 46px !important;
    }

    .role-sign-line {
      min-height: 22px !important;
    }

    .role-sign-label {
      font-size: 10px !important;
    }

    .report-disclaimer-block {
      font-size: 11px !important;
      padding: 6px 8px !important;
      margin-bottom: 8px !important;
    }

    .room-allocation-table td {
      font-size: 11px !important;
      padding: 3px 6px !important;
    }

    .report-footer {
      margin-top: 12px !important;
      padding-top: 8px !important;
    }

    .report-footer-note {
      font-size: 12px !important;
    }

    .report-final-check {
      font-size: 13px !important;
    }
  }

  body.pdf-export {
    margin: 0 !important;
    padding: 0 !important;
    background: #fff !important;
    width: 210mm !important;
  }

  body.pdf-export .print-page-shell,
  body.pdf-export .container,
  body.pdf-export .print-report {
    width: 190mm !important;
    max-width: 190mm !important;
    padding: 0 !important;
    margin: 0 auto !important;
    box-shadow: none !important;
  }

  body.pdf-export .print-report {
    font-size: 14px;
    min-height: auto;
  }
</style>

<script>
  document.documentElement.classList.add('medical-report-print');

  (function () {
    var A4_CONTENT_HEIGHT_PX = (277 / 25.4) * 96;

    function fitReportToA4() {
      if (!window.matchMedia('print').matches) return;

      var report = document.querySelector('.print-report');
      if (!report) return;

      report.style.transform = '';
      report.style.transformOrigin = 'top center';

      var contentHeight = report.scrollHeight;
      if (contentHeight > A4_CONTENT_HEIGHT_PX) {
        var scale = A4_CONTENT_HEIGHT_PX / contentHeight;
        scale = Math.max(scale, 0.82);
        report.style.transform = 'scale(' + scale + ')';
      }
    }

    function resetReportScale() {
      var report = document.querySelector('.print-report');
      if (report) report.style.transform = '';
    }

    window.addEventListener('beforeprint', fitReportToA4);
    window.addEventListener('afterprint', resetReportScale);
  })();
</script>

<% if (!locals.bundleExport) { %>
<div class="container mb-4 no-print">
  <div class="alert alert-light border py-2 px-3 mb-2 small">
    <i class="fas fa-print me-1"></i>
    For correct layout, choose <strong>A4 (210 × 297 mm)</strong> paper in the print dialog.
  </div>
  <% if (locals.blankPrint) { %>
  <div class="alert alert-info py-2 px-3 mb-2 small">
    <i class="fas fa-file me-1"></i>
    Blank template — patient details are shown; examination and lab results are left empty.
  </div>
  <% } %>
  <div class="d-flex justify-content-end gap-2 mt-2">
    <button class="btn btn-outline-secondary" onclick="window.print()">
      <i class="fas fa-print me-1"></i> <%= locals.blankPrint ? 'Print Blank' : 'Print Report' %>
    </button>
    <a href="/billing/medical-report/<%= billing.id %>" class="btn btn-primary">
      <i class="fas fa-edit me-1"></i> Edit Report
    </a>
    <a href="/billing/receipt/<%= billing.id %>" class="btn btn-outline-secondary">
      <i class="fas fa-file-invoice me-1"></i> View Invoice
    </a>
  </div>
</div>
<% } %>

<%
function fmtDate(d) {
  if (!d) return 'N/A';
  const dt = new Date(d);
  if (isNaN(dt.getTime())) return d;
  return dt.toLocaleDateString('en-GB');
}
function calcAge(dob) {
  if (!dob) return null;
  const birth = new Date(dob);
  if (isNaN(birth.getTime())) return null;
  const today = new Date();
  let age = today.getFullYear() - birth.getFullYear();
  const monthDiff = today.getMonth() - birth.getMonth();
  if (monthDiff < 0 || (monthDiff === 0 && today.getDate() < birth.getDate())) age--;
  return age;
}
const emptyMark = locals.blankPrint ? '_________' : '—';
function val(v) { return (v !== undefined && v !== null && v !== '') ? v : emptyMark; }
function elisaVal(v) { return (v !== undefined && v !== null && v !== '') ? v : 'Positive/Negative'; }
const ex = reportData.examination;
const xr = reportData.xray;
const lab = reportData.laboratory;
const patient = billing.Patient;
const patientAge = patient && patient.dateOfBirth ? calcAge(patient.dateOfBirth) : null;
const isFemalePatient = patient && String(patient.gender || '').toLowerCase() === 'female';
%>

<div class="print-page-shell">
<div class="container print-report pb-4">
  <div class="report-title"><%= locals.settings && settings.medical_name ? settings.medical_name : 'Medical Report' %></div>
  <div class="report-subtitle">Medical Examination Report</div>
  <% if (locals.settings && (settings.address || settings.phone)) { %>
  <div class="report-clinic-info">
    <% if (settings.address) { %>Address: <%= settings.address %><% } %>
    <% if (settings.address && settings.phone) { %> | <% } %>
    <% if (settings.phone) { %>Mobile: <%= settings.phone %><% } %>
  </div>
  <% } %>

  <% if (locals.blankPrint) { %>
  <div class="report-header-blank">
    <div class="header-blank-body">
      <div class="header-blank-patient">
        <div class="header-blank-col">
          <p class="header-blank-field"><strong>Patient Name:</strong> <%= patient ? patient.name : emptyMark %></p>
          <p class="header-blank-field"><strong>Gender:</strong> <%= patient && patient.gender ? patient.gender.charAt(0).toUpperCase() + patient.gender.slice(1) : emptyMark %></p>
          <p class="header-blank-field"><strong>Passport No:</strong> <%= patient && patient.nidPassportNo ? patient.nidPassportNo : emptyMark %></p>
          <p class="header-blank-field"><strong>Report Date:</strong> <%= fmtDate(reportData.reportDate) %></p>
          <p class="header-blank-field"><strong>Invoice No:</strong> <%= billing.billNumber || billing.id %><% if (patient && patient.patientId) { %> [<%= patient.patientId %>]<% } %></p>
        </div>
        <div class="header-blank-col">
          <p class="header-blank-field"><strong>Date Of Birth:</strong> <%= patient && patient.dateOfBirth ? fmtDate(patient.dateOfBirth) : emptyMark %> &nbsp; <strong>Age:</strong> <%= patientAge != null ? patientAge : emptyMark %></p>
          <p class="header-blank-field"><strong>Marital Status:</strong> <%= val(ex.marital_status) %> &nbsp; <strong>Profession:</strong> <%= val(ex.profession) %></p>
          <p class="header-blank-field"><strong>Height:</strong> <%= val(reportData.height) %> CM &nbsp; <strong>Weight:</strong> <%= val(reportData.weight) %> KG</p>
          <p class="header-blank-field"><strong>Status:</strong> <%= val(reportData.status) %></p>
          <p class="header-blank-field"><strong>Comment:</strong> <%= val(reportData.comment) %></p>
        </div>
      </div>
      <div class="header-blank-room">
        <table class="header-blank-room-table">
          <tr class="room-title-row">
            <td colspan="2"><b>Room Allocation</b></td>
          </tr>
          <tr>
            <td class="room-label-cell">Sample Collection (101)</td>
            <td class="room-blank-cell"></td>
          </tr>
          <tr>
            <td class="room-label-cell">Physcial (103)</td>
            <td class="room-blank-cell"></td>
          </tr>
          <tr>
            <td class="room-label-cell">Radiologis (104)</td>
            <td class="room-blank-cell"></td>
          </tr>
          <% if (isFemalePatient) { %>
          <tr>
            <td class="room-label-cell">Urine (101)</td>
            <td class="room-blank-cell"></td>
          </tr>
          <% } %>
        </table>
      </div>
    </div>
    <div class="header-blank-photo">
      <% const profileImgSrc = locals.bundleProfileSrc || billing.patientPhoto; %>
      <% if (profileImgSrc) { %>
      <img src="<%= profileImgSrc %>" alt="" class="patient-photo-img">
      <% } %>
    </div>
  </div>
  <% } else { %>
  <table class="report-meta-table">
    <tr>
      <td class="meta-text-left">
        <p class="meta-line"><strong>Patient Name:</strong> <%= patient ? patient.name : emptyMark %></p>
        <p class="meta-line"><strong>Passport No:</strong> <%= patient && patient.nidPassportNo ? patient.nidPassportNo : emptyMark %></p>
        <p class="meta-line"><strong>Marital Status:</strong> <%= val(ex.marital_status) %> &nbsp; <strong>Profession:</strong> <%= val(ex.profession) %></p>
        <p class="meta-line"><strong>Report Date:</strong> <%= fmtDate(reportData.reportDate) %></p>
        <p class="meta-line"><strong>Issue Date:</strong> <%= fmtDate(reportData.issueDate) %></p>
        <p class="meta-line"><strong>invoice No:</strong> <%= billing.billNumber || billing.id %><% if (patient && patient.patientId) { %> [<%= patient.patientId %>]<% } %></p>
      </td>
      <td class="meta-fingerprint">
        <img src="<%= fingerprintUrl %>" alt="" class="fingerprint-img">
      </td>
      <td class="meta-text-right">
        <p class="meta-line"><strong>Height:</strong> <%= val(reportData.height) %> CM &nbsp; <strong>Weight:</strong> <%= val(reportData.weight) %> KG</p>
        <p class="meta-line"><strong>Status:</strong> <%= val(reportData.status) %></p>
        <% if (patient) { %>
        <p class="meta-line"><strong>Gender:</strong> <%= patient.gender ? patient.gender.charAt(0).toUpperCase() + patient.gender.slice(1) : emptyMark %> &nbsp; <strong>Mobile:</strong> <%= val(patient.phone) %></p>
        <% } %>
        <p class="meta-line"><strong>Comment:</strong> <%= val(reportData.comment) %></p>
      </td>
      <td class="meta-photo">
        <% const profileImgSrc = locals.bundleProfileSrc || billing.patientPhoto; %>
        <% if (profileImgSrc) { %>
        <img src="<%= profileImgSrc %>" alt="" class="patient-photo-img">
        <% } %>
      </td>
    </tr>
  </table>
  <% } %>

  <div class="report-columns">
    <div>
      <table class="report-table report-table-2col">
        <colgroup>
          <col class="col-name">
          <col class="col-value">
        </colgroup>
        <tr class="group-row"><td colspan="2"><b>Medical Examination</b></td></tr>
        <tr><th>Type of the Examination</th><th>Results</th></tr>
        <tr>
          <td>Eye Visual Acuity</td>
          <td>R: <%= val(ex.eye_right) %> &nbsp; L: <%= val(ex.eye_left) %></td>
        </tr>
        <tr>
          <td>Ear</td>
          <td>R: <%= val(ex.ear_right) %> &nbsp; L: <%= val(ex.ear_left) %></td>
        </tr>
        <tr class="group-row"><td colspan="2">Systemic Exam: Cardio-Vascular</td></tr>
        <tr><td>Heart</td><td><%= val(ex.heart) %></td></tr>
        <tr><td>B.P.</td><td><%= val(ex.bp) %></td></tr>
        <tr><td>Pulse</td><td><%= val(ex.pulse) %></td></tr>
        <tr class="group-row"><td colspan="2">Respiratory Exam</td></tr>
        <tr><td>Lungs</td><td><%= val(ex.lungs) %></td></tr>
        <tr><td>RR/min</td><td><%= val(ex.rr_min) %></td></tr>
        <tr><td>Gastrointestinal Abdomen</td><td><%= val(ex.gastrointestinal_abdomen) %></td></tr>
        <tr class="group-row"><td colspan="2">Others</td></tr>
        <tr><td>Hernia</td><td><%= val(ex.hernia) %></td></tr>
        <tr><td>Varicoseveins</td><td><%= val(ex.varicoseveins) %></td></tr>
        <tr><td>Deformities</td><td><%= val(ex.deformities) %></td></tr>
        <tr><td>Skin</td><td><%= val(ex.skin) %></td></tr>
        <tr><td>C.N.S.</td><td><%= val(ex.cns) %></td></tr>
        <tr><td>Extremities</td><td><%= val(ex.extremities) %></td></tr>
        <tr><td>Psychiatry</td><td><%= val(ex.psychiatry) %></td></tr>
        <tr><td>Any Operation History</td><td><%= val(ex.operation_history) %></td></tr>
        <tr class="group-row"><td colspan="2">Venereal Diseases</td></tr>
        <tr><td>Symptoms</td><td><%= val(ex.venereal_diseases) %></td></tr>
        <tr class="group-row"><td colspan="2">X-Ray Investigation</td></tr>
        <tr><td>Chest X-Ray</td><td><%= val(xr.xray) %></td></tr>
        <tr><td>ECG</td><td><%= val(xr.ecg) %></td></tr>
        <tr>
          <td>X-Ray Image</td>
          <td>
            <% if (locals.blankPrint) { %>
            <%= val(null) %>
            <% } else { %>
            <img src="<%= xrayImageUrl %>" alt="X-Ray" class="xray-img">
            <% } %>
          </td>
        </tr>
      </table>

      <table class="report-table role-sign-table report-table-2col">
        <colgroup>
          <col class="col-name">
          <col class="col-value">
        </colgroup>
        <tr class="group-row"><td colspan="2"><b>Signature</b></td></tr>
        <tr>
          <td style="padding-top: 40px;">
            <hr style="margin: 0; opacity: 2;">
            <div class="role-sign-label">Pathologist</div>
          </td>
          <td style="padding-top: 40px;">
            <hr style="margin: 0; opacity: 2;">
            <div class="role-sign-label">Lab Technologist</div>
          </td>
        </tr>
        <tr>
          <td style="padding-top: 40px;">
            <hr style="margin: 0; opacity: 2;">
            <div class="role-sign-label">Radiologist</div>
          </td>
          <td style="padding-top: 40px;">
            <hr style="margin: 0; opacity: 2;">
            <div class="role-sign-label">X-Ray Technologist</div>
          </td>
        </tr>
      </table>

      <div class="report-column-extra">

        <% if (!locals.blankPrint) { %>
        <table class="room-allocation-table report-table-2col">
          <colgroup>
            <col class="col-name">
            <col class="col-value">
          </colgroup>
          <tr class="group-row">
            <td colspan="2"><b>Room Allocation</b></td>
          </tr>
          <tr>
            <td>Sample Collection</td>
            <td>101</td>
          </tr>
          <tr>
            <td>Physcial</td>
            <td>103</td>
          </tr>
          <tr>
            <td>Radiologis</td>
            <td>104</td>
          </tr>
          <% if (isFemalePatient) { %>
          <tr>
            <td>Urine</td>
            <td>101</td>
          </tr>
          <% } %>
        </table>
        <% } %>
      </div>
    </div>

    <div>
      <table class="report-table report-table-2col">
        <colgroup>
          <col class="col-name">
          <col class="col-value">
        </colgroup>
        <tr class="group-row"><td colspan="2"><b>Laboratory Investigation</b></td></tr>
        <tr><th>Type of the Examination</th><th>Results</th></tr>
        <tr class="group-row"><td colspan="2">Urine R/E</td></tr>
        <tr><td>Sugar</td><td><%= val(lab.sugar) %></td></tr>
        <tr><td>Albumin</td><td><%= val(lab.albumin) %></td></tr>
        <tr><td>Bilharziasis (If Endemic)</td><td><%= val(lab.bilharziasis) %></td></tr>
        <tr><td>Pregnancy Test</td><td><%= val(lab.pregnancy) %></td></tr>
        <tr><td>Others</td><td><%= val(lab.urine_other) %></td></tr>
        <tr class="group-row"><td colspan="2">Stool R/E (If Required)</td></tr>
        <tr><td>Helminthes</td><td><%= val(lab.helminthes) %></td></tr>
        <tr><td>Giardia</td><td><%= val(lab.giardia) %></td></tr>
        <tr><td>Bilharziasis (If Endemic)</td><td><%= val(lab.stool_bilharziasis) %></td></tr>
        <tr><td>Culture</td><td><%= val(lab.culture) %></td></tr>
        <tr class="group-row"><td colspan="2">Blood-CBC &amp; Grouping</td></tr>
        <tr><td>Malaria</td><td><%= val(lab.malaria) %></td></tr>
        <tr><td>Microfilaria</td><td><%= val(lab.microfilaria) %></td></tr>
        <tr><td>Blood Group</td><td><%= val(lab.blood_group) %></td></tr>
        <tr><td>Haemoglobin</td><td><%= val(lab.haemoglobin) %></td></tr>
        <tr><td>ESR</td><td><%= val(lab.esr) %></td></tr>
        <tr class="group-row"><td colspan="2">Blood-Biochemistry</td></tr>
        <tr>
          <td colspan="2" class="biochem-cell">
            <table class="biochem-nested-table">
              <colgroup>
                <col class="col-name">
                <col class="col-result">
                <col class="col-ref">
              </colgroup>
              <tr>
                <th>Test Name</th>
                <th>Result</th>
                <th>Reference Value</th>
              </tr>
              <% bloodBiochemistryTests.forEach(function (test) { %>
              <tr>
                <td><%= test.name %></td>
                <td><%= val(lab[test.field]) %></td>
                <td class="ref-value-cell"><%= test.reference %></td>
              </tr>
              <% }); %>
            </table>
          </td>
        </tr>
        <tr class="group-row"><td colspan="2">Blood-ELISA &amp; Serology</td></tr>
        <tr><td>HIV I &amp; HIV II</td><td><%= elisaVal(lab.hivi_hivii) %></td></tr>
        <tr><td>HBsAg</td><td><%= elisaVal(lab.hbag) %></td></tr>
        <tr><td>Anti HCV</td><td><%= elisaVal(lab.anti_hcv) %></td></tr>
        <tr><td>TPHA (If VDRL Positive)</td><td><%= elisaVal(lab.tpha) %></td></tr>
        <tr><td>VDRL</td><td><%= elisaVal(lab.vdrl) %></td></tr>
      </table>
    </div>
  </div>

  <% if (reportData.showSign) { %>
  <div class="sign-block">
    <div class="sign-line">Authorized Signature</div>
  </div>
  <% } %>

  <div class="report-footer">
    <p class="report-final-check">FINAL CHECKED BY:...........................</p>
  </div>
</div>
</div>

<% if (locals.bundleExport) { %>
</body>
</html>
<% } else { %>
<%- include('partials/footer') %>
<% } %>
