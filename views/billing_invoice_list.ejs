<%- include('partials/header') %>
<%- include('partials/navbar') %>
<%- include('partials/date-formatter') %>

<%
function formatListDate(d) {
  if (!d) return '—';
  const dt = new Date(d);
  if (isNaN(dt.getTime())) return d;
  return dt.toLocaleDateString('en-GB');
}
%>

<div class="container-fluid py-4">
  <div class="card mb-3">
    <div class="card-header d-flex justify-content-between align-items-center">
      <h5 class="mb-0">
        <i class="fas fa-list me-2"></i>Invoice List
        <small class="text-muted ms-2">
          (<%= formatListDate(filters.startDate) %>
          <% if (filters.startDate !== filters.endDate) { %>
            – <%= formatListDate(filters.endDate) %>
          <% } %>)
        </small>
      </h5>
      <div class="d-flex gap-2">
        <%
        const downloadParams = new URLSearchParams();
        downloadParams.set('startDate', filters.startDate);
        downloadParams.set('endDate', filters.endDate);
        downloadParams.set('status', filters.status);
        downloadParams.set('searchType', filters.searchType);
        if (filters.searchQuery) downloadParams.set('searchQuery', filters.searchQuery);
        if (filters.createdBy) downloadParams.set('createdBy', filters.createdBy);
        %>
        <a href="/billing/invoices/today/download?<%= downloadParams.toString() %>" class="btn btn-outline-success btn-sm">
          <i class="fas fa-file-csv me-1"></i> Export CSV
        </a>
        <button type="button" class="btn btn-success btn-sm" id="btn-download-selected" disabled>
          <i class="fas fa-download me-1"></i> Download Selected
        </button>
        <a href="/billing" class="btn btn-primary btn-sm">
          <i class="fas fa-plus me-1"></i> New Invoice
        </a>
      </div>
    </div>
    <div class="card-body border-bottom">
      <form method="GET" action="/billing/invoices/today" class="row g-3 align-items-end">
        <div class="col-md-2">
          <label for="startDate" class="form-label">From Date</label>
          <input type="date" class="form-control" id="startDate" name="startDate" value="<%= filters.startDate %>">
        </div>
        <div class="col-md-2">
          <label for="endDate" class="form-label">To Date</label>
          <input type="date" class="form-control" id="endDate" name="endDate" value="<%= filters.endDate %>">
        </div>
        <div class="col-md-2">
          <label for="status" class="form-label">Status</label>
          <select class="form-select" id="status" name="status">
            <option value="all" <%= filters.status === 'all' ? 'selected' : '' %>>All</option>
            <option value="Fit" <%= filters.status === 'Fit' ? 'selected' : '' %>>Fit</option>
            <option value="Unfit" <%= filters.status === 'Unfit' ? 'selected' : '' %>>Unfit</option>
            <option value="Held UP" <%= filters.status === 'Held UP' ? 'selected' : '' %>>Held UP</option>
            <option value="RUNNING" <%= filters.status === 'RUNNING' ? 'selected' : '' %>>RUNNING</option>
            <option value="none" <%= filters.status === 'none' ? 'selected' : '' %>>No Report</option>
          </select>
        </div>
        <div class="col-md-2">
          <label for="searchType" class="form-label">Search By</label>
          <select class="form-select" id="searchType" name="searchType">
            <option value="all" <%= filters.searchType === 'all' ? 'selected' : '' %>>All</option>
            <option value="billNumber" <%= filters.searchType === 'billNumber' ? 'selected' : '' %>>Invoice No.</option>
            <option value="passport" <%= filters.searchType === 'passport' ? 'selected' : '' %>>Passport No.</option>
            <option value="patientName" <%= filters.searchType === 'patientName' ? 'selected' : '' %>>Patient Name</option>
            <option value="patientId" <%= filters.searchType === 'patientId' ? 'selected' : '' %>>Patient ID</option>
            <option value="phone" <%= filters.searchType === 'phone' ? 'selected' : '' %>>Mobile No</option>
          </select>
        </div>
        <div class="col-md-4">
          <label for="searchQuery" class="form-label">Search Term</label>
          <input type="text" class="form-control" id="searchQuery" name="searchQuery" value="<%= filters.searchQuery %>" placeholder="e.g. a1111, a2222, a3333">
        </div>
        <% if (canFilterByCreator) { %>
        <div class="col-md-2">
          <label for="createdBy" class="form-label">Created By</label>
          <select class="form-select" id="createdBy" name="createdBy">
            <option value="" <%= !filters.createdBy ? 'selected' : '' %>>All Users</option>
            <% (creators || []).forEach(function (creator) { %>
              <option value="<%= creator.id %>" <%= String(filters.createdBy) === String(creator.id) ? 'selected' : '' %>>
                <%= creator.username %>
              </option>
            <% }); %>
          </select>
        </div>
        <% } %>
        <div class="col-md-2 d-flex gap-2">
          <button type="submit" class="btn btn-primary flex-grow-1">
            <i class="fas fa-filter me-1"></i> Filter
          </button>
          <a href="/billing/invoices/today" class="btn btn-outline-secondary" title="Reset">
            <i class="fas fa-redo"></i>
          </a>
        </div>
      </form>
    </div>
    <div class="card-body pt-0">
      <div class="d-flex align-items-center justify-content-between py-2 border-bottom">
        <small class="text-muted" id="selection-summary">0 invoice(s) selected</small>
      </div>
      <div class="table-responsive">
        <table class="table table-hover mb-0" id="invoice-list-table">
          <thead class="table-light">
            <tr>
              <th style="width: 42px;">
                <input type="checkbox" class="form-check-input" id="select-all-invoices" title="Select all" <%= (bills && bills.length > 0) ? '' : 'disabled' %>>
              </th>
              <th style="width: 50px;">SL</th>
              <th>Report Date</th>
              <th>Invoice No.</th>
              <th>Passport No.</th>
              <th>Patient Name</th>
              <th>Status</th>
              <th>Created By</th>
              <th>Created Date</th>
              <th>Action</th>
            </tr>
          </thead>
          <tbody>
            <% if (bills && bills.length > 0) { %>
              <% bills.forEach(function (bill, index) { %>
              <tr>
                <td>
                  <%
                  const hasAllPhotos = bill.takenPhoto && bill.patientPhoto && bill.passportPhoto;
                  const missingPhotos = [];
                  if (!bill.takenPhoto) missingPhotos.push('taken photo');
                  if (!bill.patientPhoto) missingPhotos.push('AI profile photo');
                  if (!bill.passportPhoto) missingPhotos.push('passport picture');
                  %>
                  <input type="checkbox" class="form-check-input bill-select" value="<%= bill.id %>"
                    data-bill-number="<%= bill.billNumber %>"
                    data-has-photos="<%= hasAllPhotos ? '1' : '0' %>"
                    data-missing-photos="<%= missingPhotos.join(', ') %>"
                    aria-label="Select invoice <%= bill.billNumber %>">
                </td>
                <td><%= index + 1 %></td>
                <td><%= bill.MedicalReport ? formatListDate(bill.MedicalReport.reportDate) : '—' %></td>
                <td><%= bill.billNumber %></td>
                <td><%= bill.Patient && bill.Patient.nidPassportNo ? bill.Patient.nidPassportNo : '—' %></td>
                <td><%= bill.Patient ? bill.Patient.name : 'Unknown' %></td>
                <td>
                  <% if (bill.MedicalReport && bill.MedicalReport.status) { %>
                  <span class="badge bg-<%= bill.MedicalReport.status === 'Fit' ? 'success' : (bill.MedicalReport.status === 'Unfit' ? 'danger' : (bill.MedicalReport.status === 'RUNNING' ? 'info' : 'warning text-dark')) %>">
                    <%= bill.MedicalReport.status %>
                  </span>
                  <% } else { %>
                  <span class="text-muted">—</span>
                  <% } %>
                </td>
                <td><%= bill.creator ? bill.creator.username : '—' %></td>
                <td><%= formatListDate(bill.createdAt) %></td>
                <td>
                  <a href="/billing/receipt/<%= bill.id %>" class="btn btn-sm btn-outline-primary" title="View Invoice">
                    <i class="fas fa-eye"></i>
                  </a>
                  <a href="/billing/edit/<%= bill.id %>" class="btn btn-sm btn-outline-secondary" title="Edit Invoice">
                    <i class="fas fa-edit"></i>
                  </a>
                  <a href="/billing/medical-report/<%= bill.id %>" class="btn btn-sm btn-outline-success" title="Medical Report">
                    <i class="fas fa-file-medical"></i>
                  </a>
                  <% if (bill.MedicalReport) { %>
                  <a href="/billing/medical-report/<%= bill.id %>/print" class="btn btn-sm btn-outline-info" title="Print Medical Report">
                    <i class="fas fa-print"></i>
                  </a>
                  <% } %>
                  <% if (bill.passportPhoto) { %>
                  <a href="/billing/passport-photo/<%= bill.id %>/download" class="btn btn-sm btn-outline-dark" title="Download Passport Picture">
                    <i class="fas fa-download"></i>
                  </a>
                  <% } %>
                </td>
              </tr>
              <% }); %>
            <% } else { %>
              <tr>
                <td colspan="10" class="text-center text-muted py-4">No invoices found for the selected filters.</td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
      <% if (totalRecords > 0) { %>
      <div class="text-center mt-3">
        <small class="text-muted"><%= totalRecords %> invoice<%= totalRecords !== 1 ? 's' : '' %> found</small>
      </div>
      <% } %>
    </div>
  </div>
</div>

<script>
(function () {
  const selectAll = document.getElementById('select-all-invoices');
  const downloadBtn = document.getElementById('btn-download-selected');
  const summaryEl = document.getElementById('selection-summary');
  const table = document.getElementById('invoice-list-table');

  function getRowCheckboxes() {
    return table ? Array.from(table.querySelectorAll('.bill-select')) : [];
  }

  function getSelectedIds() {
    return getRowCheckboxes()
      .filter(function (cb) { return cb.checked; })
      .map(function (cb) { return cb.value; });
  }

  function updateSelectionUi() {
    const boxes = getRowCheckboxes();
    const selected = getSelectedIds();
    const total = boxes.length;

    if (summaryEl) {
      summaryEl.textContent = selected.length + ' invoice(s) selected';
    }
    if (downloadBtn) {
      downloadBtn.disabled = selected.length === 0;
    }
    if (selectAll) {
      selectAll.indeterminate = selected.length > 0 && selected.length < total;
      selectAll.checked = total > 0 && selected.length === total;
    }
  }

  if (selectAll) {
    selectAll.addEventListener('change', function () {
      const checked = selectAll.checked;
      getRowCheckboxes().forEach(function (cb) {
        cb.checked = checked;
      });
      updateSelectionUi();
    });
  }

  if (table) {
    table.addEventListener('change', function (event) {
      if (event.target.classList.contains('bill-select')) {
        updateSelectionUi();
      }
    });
  }

  if (downloadBtn) {
    downloadBtn.addEventListener('click', function () {
      const selectedBoxes = getRowCheckboxes().filter(function (cb) { return cb.checked; });
      if (!selectedBoxes.length) {
        alert('Select at least one invoice.');
        return;
      }

      const incomplete = selectedBoxes.filter(function (cb) {
        return cb.dataset.hasPhotos !== '1';
      });
      if (incomplete.length) {
        const details = incomplete.map(function (cb) {
          const missing = cb.dataset.missingPhotos || 'required photos';
          return 'Invoice ' + cb.dataset.billNumber + ': missing ' + missing;
        }).join('\n');
        alert('Each selected invoice needs a taken photo, AI profile photo, and passport picture.\n\n' + details);
        return;
      }

      const ids = selectedBoxes.map(function (cb) { return cb.value; });

      downloadBtn.disabled = true;
      const originalHtml = downloadBtn.innerHTML;
      downloadBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Preparing...';

      fetch('/billing/invoices/today/download-bundle', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ ids: ids })
      })
      .then(function (res) {
        if (!res.ok) {
          return res.text().then(function (text) {
            throw new Error(text || 'Download failed');
          });
        }
        return res.blob().then(function (blob) {
          const url = URL.createObjectURL(blob);
          const link = document.createElement('a');
          const today = new Date().toISOString().slice(0, 10);
          link.href = url;
          link.download = 'invoices-' + today + '.zip';
          document.body.appendChild(link);
          link.click();
          link.remove();
          URL.revokeObjectURL(url);
        });
      })
      .catch(function (err) {
        alert(err.message || 'Could not download selected invoices');
      })
      .finally(function () {
        downloadBtn.innerHTML = originalHtml;
        updateSelectionUi();
      });
    });
  }

  updateSelectionUi();
})();
</script>

<%- include('partials/footer') %>
