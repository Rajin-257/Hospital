<%- include('partials/header') %>
<%- include('partials/navbar') %>

<style>
.photo-page {
    --photo-border: #dee2e6;
    --photo-bg: #f8f9fa;
}

.photo-page .card {
    border: 1px solid var(--photo-border);
}

.photo-page .meta-line {
    font-size: 0.8rem;
    color: #6c757d;
}

.photo-page .meta-line strong {
    color: #212529;
}

.photo-page .panel-box {
    border: 1px solid var(--photo-border);
    border-radius: 6px;
    background: #fff;
    padding: 0.75rem;
    height: 100%;
}

.photo-page .panel-heading {
    font-size: 0.85rem;
    font-weight: 600;
    color: #212529;
    margin-bottom: 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--photo-border);
}

.photo-page .panel-heading i {
    color: #4361ee;
    margin-right: 0.35rem;
}

.photo-page .webcam-wrap {
    position: relative;
    height: 220px;
    background: #212529;
    border-radius: 4px;
    overflow: hidden;
}

.photo-page .webcam-wrap video {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

.photo-page .webcam-placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    color: #adb5bd;
    font-size: 0.8rem;
    text-align: center;
    padding: 0.5rem;
}

.photo-page .upload-zone {
    height: 120px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    cursor: pointer;
    border: 1px dashed #ced4da;
    border-radius: 4px;
    background: var(--photo-bg);
    padding: 0.75rem;
    font-size: 0.8rem;
    color: #6c757d;
}

.photo-page .upload-zone.is-dragover {
    border-color: #4361ee;
    background: #eef2ff;
}

.photo-page .upload-zone input[type="file"] {
    position: absolute;
    width: 0;
    height: 0;
    opacity: 0;
}

.photo-page .upload-zone i {
    font-size: 1.25rem;
    color: #4361ee;
    margin-bottom: 0.35rem;
}

.photo-page .preview-box {
    border: 1px solid var(--photo-border);
    border-radius: 4px;
    background: var(--photo-bg);
    padding: 0.5rem;
    text-align: center;
    height: 220px;
    display: flex;
    align-items: center;
    justify-content: center;
}

.photo-page .preview-box img {
    max-height: 200px;
    max-width: 100%;
    border-radius: 4px;
}

.photo-page .preview-box.is-empty {
    color: #adb5bd;
    font-size: 0.8rem;
}

.photo-page .card-footer-bar {
    background: var(--photo-bg);
    border-top: 1px solid var(--photo-border);
    padding: 0.75rem 1rem;
}

.processing-overlay {
    position: fixed;
    inset: 0;
    z-index: 2000;
    background: rgba(15, 23, 42, 0.55);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
}

.processing-overlay[hidden] {
    display: none !important;
}

.processing-overlay-card {
    background: #fff;
    border: 1px solid var(--photo-border);
    border-radius: 8px;
    padding: 1.5rem 1.75rem;
    max-width: 420px;
    width: 100%;
    text-align: center;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
}
</style>

<div class="container-fluid py-3 photo-page">
    <div class="card">
        <div class="card-header py-2 d-flex flex-wrap align-items-center justify-content-between gap-2">
            <div>
                <h5 class="mb-0"><i class="fas fa-camera me-2"></i>Patient Photos</h5>
                <div class="meta-line mt-1">
                    <strong>Bill #<%= billing.billNumber %></strong>
                    <% if (billing.Patient) { %>
                    &nbsp;&bull;&nbsp; <%= billing.Patient.name %>
                    &nbsp;&bull;&nbsp; <%= billing.Patient.patientId %>
                    <% if (billing.Patient.nidPassportNo) { %>
                    &nbsp;&bull;&nbsp; Passport: <%= billing.Patient.nidPassportNo %>
                    <% } %>
                    <% } %>
                </div>
            </div>
            <a href="/billing/receipt/<%= billing.id %>" class="btn btn-outline-primary btn-sm">
                <i class="fas fa-receipt me-1"></i> View Receipt
            </a>
        </div>

        <div class="card-body p-3">
            <div class="row g-3">
                <!-- Camera -->
                <div class="col-md-4">
                    <div class="panel-box">
                        <div class="panel-heading"><i class="fas fa-video"></i>Camera</div>
                        <div class="webcam-wrap">
                            <video id="webcam-video" autoplay playsinline muted></video>
                            <div id="webcam-placeholder" class="webcam-placeholder">
                                <i class="fas fa-video mb-1"></i>
                                <span>Start camera to capture</span>
                            </div>
                        </div>
                        <div class="d-flex flex-wrap gap-1 mt-2">
                            <button type="button" class="btn btn-outline-primary btn-sm" id="btn-start-camera">
                                <i class="fas fa-video me-1"></i> Start
                            </button>
                            <button type="button" class="btn btn-primary btn-sm" id="btn-capture" disabled title="Capture">
                                <i class="fas fa-camera me-1"></i> Capture
                            </button>
                            <button type="button" class="btn btn-outline-secondary btn-sm" id="btn-stop-camera" disabled title="Stop">
                                <i class="fas fa-stop me-1"></i> Stop
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Taken Picture -->
                <div class="col-md-4">
                    <div class="panel-box">
                        <div class="panel-heading"><i class="fas fa-user"></i>Taken Picture</div>
                        <div id="taken-preview-empty" class="preview-box is-empty">
                            <span>No photo yet</span>
                        </div>
                        <div id="taken-preview-section" class="preview-box" style="display: none;">
                            <img id="taken-photo-preview" src="" alt="Taken photo">
                        </div>
                        <label class="upload-zone w-100 mb-0 position-relative mt-2" id="patient-upload-zone" for="photo-upload">
                            <i class="fas fa-cloud-upload-alt"></i>
                            <span>Or upload image</span>
                            <small class="d-block mt-1">JPG, PNG, WebP · 5 MB max</small>
                            <input type="file" id="photo-upload" accept="image/jpeg,image/jpg,image/png,image/webp">
                        </label>
                        <div class="mt-2" id="taken-preview-actions" style="display: none;">
                            <button type="button" class="btn btn-outline-secondary btn-sm" id="btn-retake-patient">
                                <i class="fas fa-redo me-1"></i> Retake
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Passport Picture -->
                <div class="col-md-4">
                    <div class="panel-box">
                        <div class="panel-heading"><i class="fas fa-id-card"></i>Passport Picture</div>
                        <div id="passport-preview-empty" class="preview-box is-empty">
                            <span>No passport image</span>
                        </div>
                        <div id="passport-preview-section" class="preview-box" style="display: none;">
                            <img id="passport-photo-preview" src="" alt="Passport" style="max-height:200px;">
                            <div id="passport-pdf-preview" class="text-center" style="display:none;">
                                <i class="fas fa-file-pdf fa-3x text-danger mb-2"></i>
                                <div class="small text-muted" id="passport-pdf-name"></div>
                            </div>
                        </div>
                        <label class="upload-zone w-100 mb-0 position-relative mt-2" id="passport-upload-zone" for="passport-upload">
                            <i class="fas fa-cloud-upload-alt"></i>
                            <span>Upload passport image or PDF</span>
                            <small class="d-block mt-1">JPG, PNG, WebP, PDF · 5 MB max</small>
                            <input type="file" id="passport-upload" accept="image/jpeg,image/jpg,image/png,image/webp,application/pdf,.pdf">
                        </label>
                        <div class="mt-2" id="passport-retake-wrap" style="display: none;">
                            <button type="button" class="btn btn-outline-secondary btn-sm" id="btn-retake-passport">
                                <i class="fas fa-redo me-1"></i> Choose again
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row g-3 mt-1">
                <!-- NID Picture (optional) -->
                <div class="col-md-4">
                    <div class="panel-box">
                        <div class="panel-heading"><i class="fas fa-address-card"></i>NID Picture <span class="text-muted fw-normal">(optional)</span></div>
                        <div id="nid-preview-empty" class="preview-box is-empty">
                            <span>No NID image</span>
                        </div>
                        <div id="nid-preview-section" class="preview-box" style="display: none;">
                            <img id="nid-photo-preview" src="" alt="NID" style="max-height:200px;">
                            <div id="nid-pdf-preview" class="text-center" style="display:none;">
                                <i class="fas fa-file-pdf fa-3x text-danger mb-2"></i>
                                <div class="small text-muted" id="nid-pdf-name"></div>
                            </div>
                        </div>
                        <label class="upload-zone w-100 mb-0 position-relative mt-2" id="nid-upload-zone" for="nid-upload">
                            <i class="fas fa-cloud-upload-alt"></i>
                            <span>Upload NID image or PDF</span>
                            <small class="d-block mt-1">JPG, PNG, WebP, PDF · 5 MB max</small>
                            <input type="file" id="nid-upload" accept="image/jpeg,image/jpg,image/png,image/webp,application/pdf,.pdf">
                        </label>
                        <div class="mt-2" id="nid-retake-wrap" style="display: none;">
                            <button type="button" class="btn btn-outline-secondary btn-sm" id="btn-retake-nid">
                                <i class="fas fa-redo me-1"></i> Choose again
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card-footer-bar d-flex flex-wrap align-items-center justify-content-between gap-2">
            <small class="text-muted mb-0">Taken photo and passport picture are required. NID picture is optional.</small>
            <div class="d-flex flex-wrap gap-2">
                <a href="/billing/receipt/<%= billing.id %>" class="btn btn-outline-secondary btn-sm">
                    <i class="fas fa-forward me-1"></i> Skip
                </a>
                <button type="button" class="btn btn-success btn-sm" id="btn-save-photo" disabled>
                    <i class="fas fa-check me-1"></i> Save &amp; View Receipt
                </button>
            </div>
        </div>
    </div>
</div>

<div id="processing-overlay" class="processing-overlay" hidden aria-live="polite" aria-busy="true">
    <div class="processing-overlay-card" role="alertdialog" aria-modal="true" aria-labelledby="processing-overlay-title">
        <div class="spinner-border text-primary mb-3" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
        <h6 class="mb-2" id="processing-overlay-title">Processing</h6>
        <p class="text-danger fw-semibold mb-2">Please do not close or refresh this window.</p>
        <p class="text-muted small mb-0" id="processing-overlay-message">Please wait...</p>
    </div>
</div>

<canvas id="capture-canvas" class="d-none"></canvas>

<script>
(function () {
    const billingId = '<%= billing.id %>';
    const video = document.getElementById('webcam-video');
    const canvas = document.getElementById('capture-canvas');
    const takenPreview = document.getElementById('taken-photo-preview');
    const takenPreviewSection = document.getElementById('taken-preview-section');
    const takenPreviewEmpty = document.getElementById('taken-preview-empty');
    const takenPreviewActions = document.getElementById('taken-preview-actions');
    const passportPreview = document.getElementById('passport-photo-preview');
    const passportPdfPreview = document.getElementById('passport-pdf-preview');
    const passportPdfName = document.getElementById('passport-pdf-name');
    const passportPreviewSection = document.getElementById('passport-preview-section');
    const passportPreviewEmpty = document.getElementById('passport-preview-empty');
    const passportRetakeWrap = document.getElementById('passport-retake-wrap');
    const nidPreview = document.getElementById('nid-photo-preview');
    const nidPdfPreview = document.getElementById('nid-pdf-preview');
    const nidPdfName = document.getElementById('nid-pdf-name');
    const nidPreviewSection = document.getElementById('nid-preview-section');
    const nidPreviewEmpty = document.getElementById('nid-preview-empty');
    const nidRetakeWrap = document.getElementById('nid-retake-wrap');
    const placeholder = document.getElementById('webcam-placeholder');
    const fileInput = document.getElementById('photo-upload');
    const passportInput = document.getElementById('passport-upload');
    const nidInput = document.getElementById('nid-upload');
    const patientUploadZone = document.getElementById('patient-upload-zone');
    const passportUploadZone = document.getElementById('passport-upload-zone');
    const nidUploadZone = document.getElementById('nid-upload-zone');
    const btnStart = document.getElementById('btn-start-camera');
    const btnCapture = document.getElementById('btn-capture');
    const btnStop = document.getElementById('btn-stop-camera');
    const btnRetakePatient = document.getElementById('btn-retake-patient');
    const btnRetakePassport = document.getElementById('btn-retake-passport');
    const btnRetakeNid = document.getElementById('btn-retake-nid');
    const btnSave = document.getElementById('btn-save-photo');
    const processingOverlay = document.getElementById('processing-overlay');
    const processingOverlayTitle = document.getElementById('processing-overlay-title');
    const processingOverlayMessage = document.getElementById('processing-overlay-message');

    let stream = null;
    let takenPhotoBlob = null;
    let passportPhotoBlob = null;
    let passportIsPdf = false;
    let nidPhotoBlob = null;
    let nidIsPdf = false;

    function showProcessingModal(title, message) {
        if (processingOverlayTitle) processingOverlayTitle.textContent = title;
        if (processingOverlayMessage) processingOverlayMessage.textContent = message;
        if (processingOverlay) {
            processingOverlay.hidden = false;
            document.body.classList.add('overflow-hidden');
        }
    }

    function hideProcessingModal() {
        if (processingOverlay) {
            processingOverlay.hidden = true;
        }
        document.body.classList.remove('overflow-hidden');
    }

    function revokePreviewUrl(imgEl) {
        if (imgEl && imgEl.src && imgEl.src.startsWith('blob:')) {
            URL.revokeObjectURL(imgEl.src);
        }
    }

    function updateSaveButton() {
        btnSave.disabled = !(takenPhotoBlob && passportPhotoBlob);
    }

    function setupDropzone(zone, input, onFile) {
        if (!zone || !input) return;
        zone.addEventListener('dragover', function (e) {
            e.preventDefault();
            zone.classList.add('is-dragover');
        });
        zone.addEventListener('dragleave', function () {
            zone.classList.remove('is-dragover');
        });
        zone.addEventListener('drop', function (e) {
            e.preventDefault();
            zone.classList.remove('is-dragover');
            const file = e.dataTransfer.files[0];
            if (file) onFile(file);
        });
        input.addEventListener('change', function () {
            const file = input.files[0];
            if (file) onFile(file);
        });
    }

    function showTakenPreview(blob) {
        revokePreviewUrl(takenPreview);
        takenPhotoBlob = blob;
        takenPreview.src = URL.createObjectURL(blob);
        takenPreviewEmpty.style.display = 'none';
        takenPreviewSection.style.display = 'flex';
        takenPreviewActions.style.display = 'block';
        updateSaveButton();
    }

    function clearTakenPreview() {
        revokePreviewUrl(takenPreview);
        takenPreview.src = '';
        takenPhotoBlob = null;
        takenPreviewSection.style.display = 'none';
        takenPreviewEmpty.style.display = 'flex';
        takenPreviewActions.style.display = 'none';
        fileInput.value = '';
        updateSaveButton();
    }

    function showPassportPreview(file) {
        revokePreviewUrl(passportPreview);
        passportPhotoBlob = file;
        passportIsPdf = file.type === 'application/pdf' || /\.pdf$/i.test(file.name || '');
        passportPreviewEmpty.style.display = 'none';
        passportPreviewSection.style.display = 'flex';
        passportRetakeWrap.style.display = 'block';
        if (passportIsPdf) {
            passportPreview.style.display = 'none';
            passportPdfPreview.style.display = 'block';
            passportPdfName.textContent = file.name || 'passport.pdf';
        } else {
            passportPdfPreview.style.display = 'none';
            passportPreview.style.display = 'block';
            passportPreview.src = URL.createObjectURL(file);
        }
        updateSaveButton();
    }

    function clearPassportPreview() {
        revokePreviewUrl(passportPreview);
        passportPreview.src = '';
        passportPreview.style.display = 'block';
        passportPdfPreview.style.display = 'none';
        passportPdfName.textContent = '';
        passportPhotoBlob = null;
        passportIsPdf = false;
        passportPreviewSection.style.display = 'none';
        passportPreviewEmpty.style.display = 'flex';
        passportRetakeWrap.style.display = 'none';
        passportInput.value = '';
        updateSaveButton();
    }

    function showNidPreview(file) {
        revokePreviewUrl(nidPreview);
        nidPhotoBlob = file;
        nidIsPdf = file.type === 'application/pdf' || /\.pdf$/i.test(file.name || '');
        nidPreviewEmpty.style.display = 'none';
        nidPreviewSection.style.display = 'flex';
        nidRetakeWrap.style.display = 'block';
        if (nidIsPdf) {
            nidPreview.style.display = 'none';
            nidPdfPreview.style.display = 'block';
            nidPdfName.textContent = file.name || 'nid.pdf';
        } else {
            nidPdfPreview.style.display = 'none';
            nidPreview.style.display = 'block';
            nidPreview.src = URL.createObjectURL(file);
        }
    }

    function clearNidPreview() {
        revokePreviewUrl(nidPreview);
        nidPreview.src = '';
        nidPreview.style.display = 'block';
        nidPdfPreview.style.display = 'none';
        nidPdfName.textContent = '';
        nidPhotoBlob = null;
        nidIsPdf = false;
        nidPreviewSection.style.display = 'none';
        nidPreviewEmpty.style.display = 'flex';
        nidRetakeWrap.style.display = 'none';
        nidInput.value = '';
    }

    function validateImageFile(file) {
        if (!file.type.match(/^image\/(jpeg|jpg|png|webp)$/)) {
            alert('Please select a JPEG, PNG, or WebP image.');
            return false;
        }
        if (file.size > 5 * 1024 * 1024) {
            alert('Image must be 5 MB or smaller.');
            return false;
        }
        return true;
    }

    function validatePassportFile(file) {
        const isPdf = file.type === 'application/pdf' || /\.pdf$/i.test(file.name || '');
        if (isPdf) {
            if (file.size > 5 * 1024 * 1024) {
                alert('PDF must be 5 MB or smaller.');
                return false;
            }
            return true;
        }
        return validateImageFile(file);
    }

    function validateNidFile(file) {
        return validatePassportFile(file);
    }

    setupDropzone(patientUploadZone, fileInput, function (file) {
        if (!validateImageFile(file)) { fileInput.value = ''; return; }
        showTakenPreview(file);
    });
    setupDropzone(passportUploadZone, passportInput, function (file) {
        if (!validatePassportFile(file)) { passportInput.value = ''; return; }
        showPassportPreview(file);
    });
    setupDropzone(nidUploadZone, nidInput, function (file) {
        if (!validateNidFile(file)) { nidInput.value = ''; return; }
        showNidPreview(file);
    });

    async function startCamera() {
        try {
            stream = await navigator.mediaDevices.getUserMedia({
                video: { facingMode: 'user', width: { ideal: 1280 }, height: { ideal: 720 } },
                audio: false
            });
            video.srcObject = stream;
            placeholder.style.display = 'none';
            btnCapture.disabled = false;
            btnStop.disabled = false;
            btnStart.disabled = true;
        } catch (err) {
            alert('Could not access webcam. Please allow camera permission or upload a picture instead.');
            console.error(err);
        }
    }

    function stopCamera() {
        if (stream) {
            stream.getTracks().forEach(function (track) { track.stop(); });
            stream = null;
        }
        video.srcObject = null;
        placeholder.style.display = 'flex';
        btnCapture.disabled = true;
        btnStop.disabled = true;
        btnStart.disabled = false;
    }

    btnStart.addEventListener('click', startCamera);
    btnStop.addEventListener('click', stopCamera);
    btnCapture.addEventListener('click', function () {
        if (!stream) return;
        const w = video.videoWidth;
        const h = video.videoHeight;
        if (!w || !h) {
            alert('Camera is not ready yet.');
            return;
        }
        canvas.width = w;
        canvas.height = h;
        canvas.getContext('2d').drawImage(video, 0, 0, w, h);
        canvas.toBlob(function (blob) {
            if (!blob) return;
            showTakenPreview(new File([blob], 'webcam-capture.png', { type: 'image/png' }));
        }, 'image/png');
    });

    btnRetakePatient.addEventListener('click', clearTakenPreview);
    btnRetakePassport.addEventListener('click', clearPassportPreview);
    btnRetakeNid.addEventListener('click', clearNidPreview);

    btnSave.addEventListener('click', function () {
        if (!takenPhotoBlob || !passportPhotoBlob) {
            alert('Taken photo and passport picture are both required.');
            return;
        }
        const formData = new FormData();
        formData.append('takenPhoto', takenPhotoBlob, takenPhotoBlob.name || 'taken-photo.png');
        formData.append(
            'passportPhoto',
            passportPhotoBlob,
            passportPhotoBlob.name || (passportIsPdf ? 'passport.pdf' : 'passport-upload.png')
        );
        if (nidPhotoBlob) {
            formData.append(
                'nidPhoto',
                nidPhotoBlob,
                nidPhotoBlob.name || (nidIsPdf ? 'nid.pdf' : 'nid-upload.png')
            );
        }
        btnSave.disabled = true;
        btnSave.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Saving...';
        showProcessingModal(
            'Saving Photos',
            'Please wait while your photos are being saved. Do not close or refresh this page.'
        );
        fetch('/billing/photo/' + billingId, { method: 'POST', body: formData })
        .then(function (res) { return res.json().then(function (data) { return { ok: res.ok, data: data }; }); })
        .then(function (result) {
            if (!result.ok) throw new Error(result.data.message || 'Failed to save photos');
            hideProcessingModal();
            window.location.href = result.data.redirect;
        })
        .catch(function (err) {
            alert(err.message || 'Could not save photos');
            hideProcessingModal();
            btnSave.disabled = false;
            btnSave.innerHTML = '<i class="fas fa-check me-1"></i> Save &amp; View Receipt';
            updateSaveButton();
        });
    });

    window.addEventListener('beforeunload', function (e) {
        if (processingOverlay && !processingOverlay.hidden) {
            e.preventDefault();
            e.returnValue = '';
            return '';
        }
        stopCamera();
    });
})();
</script>

<%- include('partials/footer') %>
