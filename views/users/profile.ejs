<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="container py-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h2><i class="fas fa-id-card me-2"></i>My Profile</h2>
            <p class="text-muted">View and update your account information</p>
        </div>
    </div>

    <div class="row">
        <!-- Basic Information Card -->
        <div class="col-md-6 mb-4">
            <div class="card h-100">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="fas fa-user me-2"></i>Basic Information</h5>
                    <button class="btn btn-sm btn-primary edit-profile" data-id="<%= user.id %>">
                        <i class="fas fa-edit me-1"></i> Edit
                    </button>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="text-muted mb-1">Username</label>
                        <p class="fw-bold mb-3"><%= user.username %></p>
                    </div>
                    <div class="mb-3">
                        <label class="text-muted mb-1">Email</label>
                        <p class="fw-bold mb-3"><%= user.email %></p>
                    </div>
                    <div class="mb-3">
                        <label class="text-muted mb-1">Role</label>
                        <p class="mb-0">
                            <% if (user.role === 'softadmin') { %>
                                <span class="badge bg-primary">Soft Admin</span>
                            <% } else if (user.role === 'admin') { %>
                                <span class="badge bg-success">admin</span>
                            <% } else if (user.role === 'doctor') { %>
                                <span class="badge bg-success">Doctor</span>
                            <% } else if (user.role === 'receptionist') { %>
                                <span class="badge bg-info">Receptionist</span>
                            <% } else { %>
                                <span class="badge bg-secondary"><%= user.role %></span>
                            <% } %>
                        </p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Account Status Card -->
        <div class="col-md-6 mb-4">
            <div class="card h-100">
                <div class="card-header">
                    <h5 class="mb-0"><i class="fas fa-shield-alt me-2"></i>Account Status</h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="text-muted mb-1">Status</label>
                        <p class="mb-3">
                            <% if (user.isActive) { %>
                                <span class="badge bg-success">Active</span>
                            <% } else { %>
                                <span class="badge bg-danger">Inactive</span>
                            <% } %>
                        </p>
                    </div>
                    <div class="mb-3">
                        <label class="text-muted mb-1">Joined On</label>
                        <p class="fw-bold mb-3"><%= new Date(user.createdAt).toLocaleString() %></p>
                    </div>
                    <div>
                        <label class="text-muted mb-1">Last Updated</label>
                        <p class="fw-bold mb-0"><%= new Date(user.updatedAt).toLocaleString() %></p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Security Card -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="fas fa-lock me-2"></i>Security</h5>
                    <button class="btn btn-sm btn-primary change-password" data-id="<%= user.id %>">
                        <i class="fas fa-key me-1"></i> Change Password
                    </button>
                </div>
                <div class="card-body">
                    <p>For security reasons, you should change your password regularly. Use a strong password with a mix of letters, numbers, and special characters.</p>
                </div>
            </div>
        </div>
    </div>

    <% if (['laboratorist', 'receptionist'].includes(user.role)) { %>
    <!-- AI Portrait Settings -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card border-primary">
                <div class="card-header bg-primary text-white d-flex align-items-center justify-content-between">
                    <h5 class="mb-0"><i class="fas fa-magic me-2"></i>AI Portrait Settings</h5>
                    <span class="badge bg-white text-primary"><%= user.role === 'receptionist' ? 'Receptionist' : 'Laboratorist' %></span>
                </div>
                <div class="card-body">
                    <p class="text-muted small mb-3">Upload your hospital background image and set a custom AI prompt. These settings are private to your account and will be used when generating AI portraits.</p>
                    <div class="row g-3">
                        <div class="col-md-5">
                            <label class="form-label fw-semibold">Hospital Background Image</label>
                            <div id="bg-preview-wrap" class="mb-2 <%= user.hospitalBg ? '' : 'd-none' %>">
                                <img id="bg-preview-img" src="<%= user.hospitalBg || '' %>" alt="Background" class="img-thumbnail" style="max-height:160px; max-width:100%;">
                            </div>
                            <div id="bg-empty-label" class="text-muted small mb-2 <%= user.hospitalBg ? 'd-none' : '' %>">No background image set.</div>
                            <input type="file" class="form-control form-control-sm" id="lab-bg-input" accept="image/jpeg,image/jpg,image/png,image/webp">
                            <div class="form-text">JPG, PNG, WebP · 5 MB max · Replaces existing background</div>
                        </div>
                        <div class="col-md-7">
                            <label class="form-label fw-semibold">AI Prompt</label>
                            <textarea class="form-control font-monospace" id="lab-prompt-input" rows="7"
                              placeholder="Leave blank to use the system default. Example&#10;&#10;You are given two images: image 1 is the person, image 2 is the background. Place the person from image 1 in front of the background from image 2. Keep the exact face, hairstyle, skin tone and shirt. Ultra realistic, 4K."><%= user.aiPrompt || '' %></textarea>
                            <div class="form-text">
                              <strong>Tip:</strong> Always reference <em>image 1</em> (person) and <em>image 2</em> (background) in your prompt so the AI knows which is which. Leave blank to use the system default.
                            </div>
                        </div>
                    </div>
                    <div class="mt-3 d-flex align-items-center gap-2">
                        <button type="button" class="btn btn-primary" id="btn-save-lab-settings">
                            <i class="fas fa-save me-1"></i> Save AI Settings
                        </button>
                        <span id="lab-settings-status" class="small"></span>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <% } %>
</div>

<!-- Edit Profile Modal -->
<div class="modal fade" id="editProfileModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="fas fa-user-edit me-2"></i>Edit Profile</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="edit-profile-form">
                <input type="hidden" id="edit-user-id" name="id" value="<%= user.id %>">
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label required-label">Username</label>
                        <input type="text" class="form-control" id="edit-username" name="username" value="<%= user.username %>" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label required-label">Email</label>
                        <input type="email" class="form-control" id="edit-email" name="email" value="<%= user.email %>" required>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary"><i class="fas fa-save me-1"></i> Update Profile</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Change Password Modal -->
<div class="modal fade" id="passwordModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="fas fa-key me-2"></i>Change Password</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="password-form">
                <input type="hidden" id="password-user-id" name="id" value="<%= user.id %>">
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label required-label">Current Password</label>
                        <input type="password" class="form-control" id="current-password" name="currentPassword" required minlength="6">
                    </div>
                    <div class="mb-3">
                        <label class="form-label required-label">New Password</label>
                        <input type="password" class="form-control" id="password" name="password" required minlength="6">
                    </div>
                    <div class="mb-3">
                        <label class="form-label required-label">Confirm New Password</label>
                        <input type="password" class="form-control" id="confirmPassword" required minlength="6">
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary"><i class="fas fa-save me-1"></i> Update Password</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    $(document).ready(function() {
        // Edit profile - show modal
        $('.edit-profile').on('click', function() {
            $('#editProfileModal').modal('show');
        });
        
        // Edit profile - submit form
        $('#edit-profile-form').on('submit', function(e) {
            e.preventDefault();
            
            const userId = $('#edit-user-id').val();
            
            $.ajax({
                url: `/profile/update`,
                type: 'PUT',
                data: $(this).serialize(),
                success: function(response) {
                    $('#editProfileModal').modal('hide');
                    showToast('Profile updated successfully');
                    setTimeout(() => {
                        window.location.reload();
                    }, 1000);
                },
                error: function(error) {
                    showToast('Error updating profile: ' + (error.responseJSON?.message || 'Unknown error'), 'error');
                }
            });
        });
        
        // Change password - show modal
        $('.change-password').on('click', function() {
            $('#passwordModal').modal('show');
        });
        
        // Password validation
        $('#password-form').on('submit', function(e) {
            e.preventDefault();
            
            const password = $('#password').val();
            const confirmPassword = $('#confirmPassword').val();
            
            if (password !== confirmPassword) {
                showToast('Passwords do not match', 'error');
                return;
            }
            
            $.ajax({
                url: `/profile/change-password`,
                type: 'POST',
                data: $(this).serialize(),
                success: function(response) {
                    $('#passwordModal').modal('hide');
                    showToast('Password changed successfully');
                    
                    // Clear form
                    $('#current-password').val('');
                    $('#password').val('');
                    $('#confirmPassword').val('');
                },
                error: function(error) {
                    showToast('Error: ' + (error.responseJSON?.message || 'Unknown error'), 'error');
                }
            });
        });

        // Laboratorist AI settings
        const labBgInput = document.getElementById('lab-bg-input');
        const labBgPreviewWrap = document.getElementById('bg-preview-wrap');
        const labBgPreviewImg = document.getElementById('bg-preview-img');
        const labBgEmptyLabel = document.getElementById('bg-empty-label');
        const labPromptInput = document.getElementById('lab-prompt-input');
        const btnSaveLabSettings = document.getElementById('btn-save-lab-settings');
        const labSettingsStatus = document.getElementById('lab-settings-status');

        if (labBgInput) {
            labBgInput.addEventListener('change', function () {
                const file = labBgInput.files[0];
                if (!file) return;
                if (labBgPreviewImg) {
                    labBgPreviewImg.src = URL.createObjectURL(file);
                }
                if (labBgPreviewWrap) labBgPreviewWrap.classList.remove('d-none');
                if (labBgEmptyLabel) labBgEmptyLabel.classList.add('d-none');
            });
        }

        if (btnSaveLabSettings) {
            btnSaveLabSettings.addEventListener('click', function () {
                const formData = new FormData();
                if (labBgInput && labBgInput.files[0]) {
                    formData.append('hospitalBg', labBgInput.files[0]);
                }
                if (labPromptInput) {
                    formData.append('aiPrompt', labPromptInput.value || '');
                }
                btnSaveLabSettings.disabled = true;
                btnSaveLabSettings.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Saving...';
                if (labSettingsStatus) labSettingsStatus.textContent = '';

                fetch('/profile/lab-settings', { method: 'POST', body: formData })
                .then(function (r) { return r.json().then(function (d) { return { ok: r.ok, d }; }); })
                .then(function (result) {
                    if (!result.ok) throw new Error(result.d.message || 'Save failed');
                    if (labSettingsStatus) {
                        labSettingsStatus.textContent = 'Saved successfully';
                        labSettingsStatus.className = 'small text-success';
                    }
                    if (result.d.hospitalBg && labBgPreviewImg) {
                        labBgPreviewImg.src = result.d.hospitalBg + '?t=' + Date.now();
                        if (labBgPreviewWrap) labBgPreviewWrap.classList.remove('d-none');
                        if (labBgEmptyLabel) labBgEmptyLabel.classList.add('d-none');
                    }
                    if (labBgInput) labBgInput.value = '';
                })
                .catch(function (err) {
                    if (labSettingsStatus) {
                        labSettingsStatus.textContent = err.message || 'Error saving settings';
                        labSettingsStatus.className = 'small text-danger';
                    }
                })
                .finally(function () {
                    btnSaveLabSettings.disabled = false;
                    btnSaveLabSettings.innerHTML = '<i class="fas fa-save me-1"></i> Save AI Settings';
                });
            });
        }
    });
</script> 