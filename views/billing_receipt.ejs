// Date formatting helper function
function formatDate(date) {
    if (!date) return 'N/A';
    
    const d = new Date(date);
    if (isNaN(d.getTime())) return 'Invalid Date';
    
    const day = d.getDate().toString().padStart(2, '0');
    const month = d.toLocaleString('en-US', { month: 'short' });
    const year = d.getFullYear().toString().slice(-2);
    
    return `${day}-${month}-${year}`;
}

const items = typeof billing.items === 'string' ? JSON.parse(billing.items) : (billing.items || []);
const appointments = items.filter(item => item.type === 'appointment');
const cabins = items.filter(item => item.type === 'cabin');
const tests = items.filter(item => item.type === 'test');

// Format date of birth as dd/mm/yyyy
function formatDob(dateOfBirth) {
    if (!dateOfBirth) return 'N/A';
    const parts = String(dateOfBirth).split('T')[0].split('-');
    if (parts.length !== 3) return 'N/A';
    return `${parts[2]}/${parts[1]}/${parts[0]}`;
}

// Function to format amounts - removes decimal for print, keeps for screen
function formatAmount(amount) {
    // When printing, show without decimal places
    return `<span class="print-no-decimal">Tk ${Math.round(parseFloat(amount))}</span><span class="no-print">Tk ${parseFloat(amount).toFixed(2)}</span>`;
}

%>

<% const receiptCopies = ['Office Copy', 'Patient Copy']; %>
<div class="print-invoice-stack">
<div class="print-page-shell">
<% receiptCopies.forEach(function(copyLabel, copyIndex) { %>
<% if (copyIndex === 1) { %>
<div class="print-copy-divider"></div>
<% } %>
<div class="print-invoice<%= copyIndex > 0 ? ' print-invoice-copy' : '' %>">
<%- include('partials/billing_receipt_body', {
  copyLabel: copyLabel,
  formatDob: formatDob,
  formatDate: formatDate,
  formatAmount: formatAmount,
  items: items,
  appointments: appointments,
  cabins: cabins,
  tests: tests
}) %>
</div>
<% }); %>
</div>
