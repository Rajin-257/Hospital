                        <div class="input-group">
                            <span class="input-group-text">Tk</span>
                            <input type="number" class="form-control" id="second-discount-amount" name="secondDiscountAmount">
                        </div>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Amount</label>
                        <div class="input-group">
                            <span class="input-group-text">Tk </span>
                            <input type="number" class="form-control" id="payment-amount" name="paidAmount" value="<%= parseFloat(billing.dueAmount).toFixed(2) %>" max="<%= parseFloat(billing.dueAmount).toFixed(2) %>" min="0.01" step="0.01" required>
                        </div>
                    </div>
                    <div class="col-md-2">
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="fas fa-check-circle me-1"></i> Process
                        </button>
                    </div>
                </div>

                <div class="row mt-3">
                    <div class="col-md-12">
                        <div class="alert alert-info mb-0">
                            <div class="d-flex justify-content-between align-items-center">
                                <span>Previous Paid Amount: </span>
                                <strong>Tk <span id="previous-paid-amount"><%= parseFloat(billing.paidAmount).toFixed(2) %></span></strong>
                            </div>
                            <div class="d-flex justify-content-between align-items-center">
                                <span>Current Due Amount: </span>
                                <strong>Tk <span id="current-due-amount"><%= parseFloat(billing.dueAmount).toFixed(2) %></span></strong>
                            </div>
                            <div class="d-flex justify-content-between align-items-center">
                                <span>Additional Discount: </span>
                                <strong>Tk <span id="second-discount-total">0.00</span></strong>
                            </div>
                            <div class="d-flex justify-content-between align-items-center">
                                <span>Final Due Amount: </span>
                                <strong>Tk <span id="final-due-amount"><%= parseFloat(billing.dueAmount).toFixed(2) %></span></strong>
                            </div>
                            <div class="d-flex justify-content-between align-items-center">
                                <span>Total Amount After Payment: </span>
                                <strong>Tk <span id="total-after-payment"><%= parseFloat(billing.paidAmount).toFixed(2) %></span></strong>
                            </div>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    // Auto-scaling: fit both copies + divider on one A4 page
    const A4_CONTENT_HEIGHT_PX = (277 / 25.4) * 96;
    const A4_CONTENT_WIDTH_PX = (190 / 25.4) * 96;

    function scaleToFit() {
        if (!window.matchMedia('print').matches) return;

        const shell = document.querySelector('.print-invoice-stack .print-page-shell');
        if (!shell) return;

        shell.style.transform = '';
        shell.style.transformOrigin = 'top center';
        shell.querySelectorAll('.print-invoice').forEach(function(content) {
            content.style.setProperty('--scale-factor', 1);
        });

        const totalHeight = shell.scrollHeight;
        const totalWidth = shell.scrollWidth;
        let scaleFactor = 1;

        if (totalHeight > A4_CONTENT_HEIGHT_PX) {
            scaleFactor = Math.min(scaleFactor, A4_CONTENT_HEIGHT_PX / totalHeight);
        }
        if (totalWidth > A4_CONTENT_WIDTH_PX) {
            scaleFactor = Math.min(scaleFactor, A4_CONTENT_WIDTH_PX / totalWidth);
        }

        if (scaleFactor < 1) {
            scaleFactor = Math.max(scaleFactor, 0.65);
            shell.style.transform = 'scale(' + scaleFactor + ')';
        }
    }

    function resetScale() {
        const shell = document.querySelector('.print-invoice-stack .print-page-shell');
        if (!shell) return;
        shell.style.transform = '';
        shell.querySelectorAll('.print-invoice').forEach(function(content) {
            content.style.setProperty('--scale-factor', 1);
        });
    }
    
    // Run before printing and on load to prepare
    window.addEventListener('beforeprint', scaleToFit);
    window.addEventListener('afterprint', resetScale);
    window.addEventListener('load', function() {
        // Dynamically add ultra-compact styles if needed
        const style = document.createElement('style');
        style.textContent = `
            @media print {
                .ultra-compact .invoice-table td, .ultra-compact .invoice-table th {
                    padding: 0px 2px !important;
                    line-height: 1.1 !important;
                }
                .ultra-compact .seal-container {
                    width: 70px !important;
                    height: 70px !important;
                }
            }
        `;
        document.head.appendChild(style);
    });
    
    // For payment form
    $(document).ready(function() {
        function updateSecondDiscount() {
            const previousPaidAmount = parseFloat($('#previous-paid-amount').text());
            const currentDueAmount = parseFloat($('#current-due-amount').text());
            const secondDiscountPercent = parseFloat($('#second-discount-percent').val()) || 0;
            const secondDiscountAmount = parseFloat($('#second-discount-amount').val()) || 0;
            
            // Calculate total second discount (either from percentage or direct amount)
            let totalSecondDiscount;
            if (secondDiscountAmount > 0) {
                totalSecondDiscount = secondDiscountAmount;
                // Update percentage if amount is manually entered - keep 2 decimal places
                const calculatedPercent = (secondDiscountAmount / currentDueAmount * 100).toFixed(2);
                $('#second-discount-percent').val(calculatedPercent);
            } else {
                // Calculate discount with higher precision
                totalSecondDiscount = (currentDueAmount * (secondDiscountPercent / 100));
                // Round to 2 decimal places for display
                $('#second-discount-amount').val(totalSecondDiscount.toFixed(2));
            }

            // Ensure discount doesn't exceed the current due amount
            if (totalSecondDiscount > currentDueAmount) {
                totalSecondDiscount = currentDueAmount;
                $('#second-discount-amount').val(totalSecondDiscount.toFixed(2));
                $('#second-discount-percent').val('100.00');
            }

            const finalDueAmount = currentDueAmount - totalSecondDiscount;

            // Update display values with 2 decimal precision
            $('#second-discount-total').text(totalSecondDiscount.toFixed(2));
            $('#final-due-amount').text(finalDueAmount.toFixed(2));
            $('#payment-amount').attr('max', finalDueAmount.toFixed(2));
            $('#payment-amount').val(finalDueAmount.toFixed(2));
            
            // Calculate total after payment
            const paymentAmount = parseFloat($('#payment-amount').val()) || 0;
            const totalAfterPayment = previousPaidAmount + paymentAmount;
            $('#total-after-payment').text(totalAfterPayment.toFixed(2));
        }   

        // Add event listeners for second discount inputs and payment amount
        $('#second-discount-percent').on('input', function() {
            // Ensure the percentage doesn't exceed 100
            let value = parseFloat($(this).val());
            if (value > 100) {
                $(this).val('100.00');
            }
            updateSecondDiscount();
        });

        $('#second-discount-amount, #payment-amount').on('input', function() {
            updateSecondDiscount();
        });

        $('#payment-form').on('submit', function(e) {
            e.preventDefault();
            const previousPaidAmount = parseFloat($('#previous-paid-amount').text());
            const paymentAmount = parseFloat($('#payment-amount').val()) || 0;
            const currentDueAmount = parseFloat($('#current-due-amount').text());
            const totalAfterPayment = previousPaidAmount + paymentAmount;
            
            const paymentData = {
                paidAmount: totalAfterPayment,
                paymentMethod: $('#payment-method').val(),
                secondDiscountPercentage: $('#second-discount-percent').val(),
                secondDiscountAmount: $('#second-discount-amount').val(),
                previousPaidAmount: $('#previous-paid-amount').text()
            };
            
            $.ajax({
                url: '/billing/<%= billing.id %>/payment',
                type: 'PUT',
                data: paymentData,
                success: function(response) {
                    location.reload();
                },
                error: function(error) {
                    alert('Error processing payment. Please try again.');
                    console.error(error);
                }
            });
        });
    });
</script>
<% } %>

<%- include('partials/footer') %>
